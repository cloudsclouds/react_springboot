<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.server_springboot.mapper.UserAccountMapper">

  <select id="findByEmail" parameterType="string" resultType="com.example.server_springboot.entity.UserAccount">
    SELECT id, email, password, nickname
    FROM users
    WHERE email = #{email}
    LIMIT 1
  </select>

</mapper>